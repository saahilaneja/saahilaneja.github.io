---
import Layout from '../layouts/Layout.astro';

const FAVORITES = {
  stories: [
    'Scott Pilgrim',
    'Goodnight Punpun',
    'Durarara!!',
    'Look Back',
    'The Metamorphosis',
    'No Longer Human',
    'Chainsaw Man',
    'The Tatami Galaxy',
    'Mob Psycho 100',
    'Community',
    'Atlanta',
    'Mr. Robot',
    'Samurai Champloo',
    'Mr. Plankton',
    'Welcome to the NHK!',
    'Soul Eater',
    'Delicious in Dungeon',
    'Death Note',
    'Zetsubou-Sensei'
  ],
  games: [
    'Shin Megami Tensei',
    'VA-11 Hall-A',
    'Katana ZERO',
    'Fields of Mistria',
    'Hollow Knight',
    'The World Ends with You',
    'Metaphor: ReFantazio',
    'Yakuza',
    'PaRappa the Rapper',
    'Cyberpunk 2077'
  ],
  music: [
    'A$AP Rocky',
    'Sampha',
    'Gorillaz',
    'Nujabes',
    'Kendrick Lamar',
    'Frank Ocean',
    'N.E.R.D.',
    'TV Girl',
    'PinkPantheress',
    'The Marias',
    'Puzzle',
    'Flying Lotus',
    'Machine Girl',
    'Ryota Kozuka',
    'Pi\'erre Bourne',
    'Garoad',
    'Paris Texas',
    'Mac Miller',
    'Kahlil Blu'
  ],
} as const;
---

<Layout title="About — Saahil Aneja">
  <article class="about">
    <div class="about__body">
      <section class="about__section">
        <h1 class="about__title">Hey, I'm Saahil.</h1>
        <p>
          Born in Detroit, raised in Germany, bounced back to Michigan, spent some time in Oregon, and then somehow ended up in West Lafayette. At this point moving around is just kind of how I'm built. I think it's why I care so much about things that feel genuine. You can tell when something comes from somewhere real.
        </p>
        <p>
          I'm a junior studying CS and psychology, which are two fields that are basically just different ways of asking why things break and who's responsible. I'm currently working on XR simulations at Purdue's <a class="inline-link" href="https://www.rcac.purdue.edu/envision" target="_blank" rel="noreferrer">Envision Center</a>, and I'm deeply, perhaps concerningly, invested in Detroit sports and the state of hip-hop. I make <a class="inline-link" href="https://jam.ms" target="_blank" rel="noreferrer">games</a> with friends, program, do some sound design, and have very strong opinions about the current status of the world, social media, and the things we consume.
        </p>
        <p>
          What drives me is making things that make you feel something. Stories, games, music, whatever form it takes. If I'm not in tears by the end, was it ever truly great? There's so much stuff out there that's been polished into forgettableness, and I'd rather make something weird and alive than something clean and nothing.
        </p>
        <p class="about__closing">
          Nice to meet you!
          <a class="about__email" href="mailto:saahil@jam.ms">saahil@jam.ms</a>
        </p>
      </section>

      <section class="about__section">
        <div class="about__heading-row">
          <h2 class="about__heading">Favorites</h2>
          <button type="button" class="favorites-dice" data-dice aria-label="Reroll favorites" title="Reroll favorites">
            <span class="dice" aria-hidden="true"></span>
          </button>
        </div>
        <div class="faves">
          <div class="faves__group">
            <h3 class="faves__label">Stories</h3>
            <ul class="faves__items" data-faves="stories">
              {FAVORITES.stories.slice(0, 3).map((t) => (
                <li>{t}</li>
              ))}
            </ul>
          </div>
          <div class="faves__group">
            <h3 class="faves__label">Games</h3>
            <ul class="faves__items" data-faves="games">
              {FAVORITES.games.slice(0, 3).map((t) => (
                <li>{t}</li>
              ))}
            </ul>
          </div>
          <div class="faves__group">
            <h3 class="faves__label">Music</h3>
            <ul class="faves__items" data-faves="music">
              {FAVORITES.music.slice(0, 3).map((t) => (
                <li>{t}</li>
              ))}
            </ul>
          </div>
        </div>
      </section>
    </div>

    <aside class="friend-gacha" aria-label="Friend capsule gacha">
      <button type="button" class="friend-gacha__button" data-friend-gacha aria-label="Pull a friend capsule">
        <span class="friend-gacha__glare" aria-hidden="true"></span>
        <span class="friend-gacha__grain" aria-hidden="true"></span>
        <span class="friend-gacha__capsule" data-friend-gacha-capsule hidden>
          <span class="friend-gacha__shell" data-friend-gacha-shell data-shell-frame="1">
            <img class="friend-gacha__shellFrame" src="/gacha/capsules/capsule1.png" alt="" loading="lazy" decoding="async" />
            <img class="friend-gacha__shellFrame" src="/gacha/capsules/capsule2.png" alt="" loading="lazy" decoding="async" />
            <img class="friend-gacha__shellFrame" src="/gacha/capsules/capsule3.png" alt="" loading="lazy" decoding="async" />
          </span>
          <span class="friend-gacha__face" data-friend-face>
            <img class="friend-gacha__icon" data-friend-gacha-icon alt="" />
            <span class="friend-gacha__link" data-friend-link aria-hidden="true"></span>
          </span>
        </span>
        <span class="friend-gacha__machine" data-friend-gacha-machine data-frame="1" aria-hidden="true">
          <img class="friend-gacha__frame" src="/gacha/gachapon/gachapon.png" alt="" loading="lazy" decoding="async" />
          <img class="friend-gacha__frame" src="/gacha/gachapon/gachapon2.png" alt="" loading="lazy" decoding="async" />
          <img class="friend-gacha__frame" src="/gacha/gachapon/gachapon3.png" alt="" loading="lazy" decoding="async" />
        </span>
        <span class="friend-gacha__machine-label" data-machine-label aria-hidden="true">my friends</span>
        <span class="friend-gacha__sr" data-friend-gacha-sr>Friend capsule gachapon</span>
      </button>
    </aside>

    <nav class="about__nav">
      <a href="/">← Home</a>
      <a href="/work">Work →</a>
    </nav>
  </article>
</Layout>

<script define:vars={{ FAVORITES }}>
  function pickN(arr, n) {
    const copy = arr.slice();
    for (let i = copy.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [copy[i], copy[j]] = [copy[j], copy[i]];
    }
    return copy
      .slice(0, n)
      .sort((a, b) => String(a).length - String(b).length);
  }

  function renderList(ul, items) {
    ul.innerHTML = '';
    for (const t of items) {
      const li = document.createElement('li');
      li.textContent = t;
      ul.appendChild(li);
    }
  }

  const timeoutState = new WeakMap();

  function haptic(pattern) {
    if (!('vibrate' in navigator)) return;
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    try {
      navigator.vibrate(pattern);
    } catch {}
  }

  function clearTimers(ul) {
    const ids = timeoutState.get(ul);
    if (Array.isArray(ids)) {
      for (const id of ids) clearTimeout(id);
    }
    timeoutState.set(ul, []);
  }

  function setDiceFace(dice, face) {
    if (!dice) return;
    dice.dataset.face = String(face);
  }

  function randomFace() {
    return 1 + Math.floor(Math.random() * 6);
  }

  function animateRoulette(ul, pool, onDone) {
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    let previous = [];
    if (ul.dataset.lastFinal) {
      try {
        const parsed = JSON.parse(ul.dataset.lastFinal);
        if (Array.isArray(parsed)) previous = parsed;
      } catch {}
    }

    const candidatePool = pool.filter((item) => !previous.includes(item));
    const source = candidatePool.length >= 3 ? candidatePool : pool;
    const finalPick = pickN(source, 3);
    if (reduce) {
      renderList(ul, finalPick);
      if (typeof onDone === 'function') onDone();
      return;
    }

    clearTimers(ul);
    ul.dataset.spinning = 'true';

    const steps = 4;
    const stepDelay = 200;
    const ids = [];

    for (let i = 0; i < steps; i++) {
      const isLast = i === steps - 1;
      const id = setTimeout(() => {
        if (isLast) {
          renderList(ul, finalPick);
          ul.dataset.lastFinal = JSON.stringify(finalPick);
          ul.dataset.spinning = 'false';
          if (typeof onDone === 'function') onDone();
        } else {
          const dice = document.querySelector('[data-dice]');
          if (dice) setDiceFace(dice, randomFace());
          renderList(ul, pickN(pool, 3));
        }
      }, i * stepDelay + Math.random() * 60);
      ids.push(id);
    }
    timeoutState.set(ul, ids);
  }

  function runFavorites() {
    const dice = document.querySelector('[data-dice]');
    if (dice) {
      dice.dataset.rolling = 'true';
      setDiceFace(dice, randomFace());
      haptic([12, 18, 10, 18, 8]);
    }

    const uls = Array.from(document.querySelectorAll('.faves__items[data-faves]'));
    let remaining = uls.length;

    function done() {
      remaining -= 1;
      if (remaining <= 0) {
        if (dice) {
          dice.dataset.rolling = 'false';
          setDiceFace(dice, randomFace());
        }
      }
    }

    uls.forEach((ul) => {
      const key = ul.getAttribute('data-faves');
      const pool = FAVORITES?.[key] ?? [];
      if (!Array.isArray(pool) || pool.length < 3) return;
      animateRoulette(ul, pool, done);
    });
  }

  function bindDice() {
    const dice = document.querySelector('[data-dice]');
    if (!dice) return;
    dice.addEventListener('click', () => runFavorites());
  }

  const FRIEND_GACHA = [
    {
      id: 'j',
      name: 'Jadden',
      icon: '/gacha/friends/icons/jstickerd.png',
      url: 'https://jaddens.page',
      rarity: 'common',
      weight: 1,
    },
    {
      id: 'a',
      name: 'Alicia',
      icon: '/gacha/friends/icons/astickerd.png',
      url: 'https://alicias.page',
      rarity: 'common',
      weight: 1,
    },
  ];

  const STORAGE_LAST = 'friend-gacha:last';

  function bindFriendGacha() {
    const btn = document.querySelector('[data-friend-gacha]');
    if (!btn || btn.dataset.bound === 'true') return;
    btn.dataset.bound = 'true';

    const capsule = btn.querySelector('[data-friend-gacha-capsule]');
    const icon = btn.querySelector('[data-friend-gacha-icon]');
    const machine = btn.querySelector('[data-friend-gacha-machine]');
    const shell = capsule?.querySelector('[data-friend-gacha-shell]');
    const link = btn.querySelector('[data-friend-link]');
    let selectedUrl = '';

    if (capsule) {
      capsule.hidden = true;
      capsule.dataset.pulling = 'false';
      capsule.dataset.pulsing = 'false';
    }
    function resetShell() {
      if (!shell) return;
      shell.dataset.shellFrame = '1';
      shell.dataset.shaking = 'false';
      shell.dataset.open = 'false';
    }
    resetShell();
    btn.dataset.ready = 'false';
    if (link) link.textContent = '';
    if (icon) {
      icon.removeAttribute('src');
      icon.alt = '';
    }
    if (machine) machine.dataset.frame = '1';

    function formatUrl(url) {
      try {
        const u = new URL(url);
        let host = u.hostname;
        if (host.startsWith('www.')) host = host.slice(4);
        const path = u.pathname && u.pathname !== '/' ? u.pathname : '';
        return `${host}${path}`;
      } catch {
        return String(url).replace(/^https?:\/\//, '').replace(/\/$/, '');
      }
    }

    function weightedPick(excludeId) {
      const pool = FRIEND_GACHA.filter((f) => f.id !== excludeId);
      const source = pool.length ? pool : FRIEND_GACHA;
      const total = source.reduce((sum, f) => sum + (typeof f.weight === 'number' ? f.weight : 1), 0);
      let r = Math.random() * (total || 1);
      for (const f of source) {
        r -= typeof f.weight === 'number' ? f.weight : 1;
        if (r <= 0) return f;
      }
      return source[source.length - 1];
    }

    function startRoll(friend) {
      btn.disabled = true;
      btn.dataset.ready = 'false';
      machine.dataset.animating = 'true';
      capsule.hidden = true;
      capsule.dataset.pulling = 'false';
      capsule.dataset.pulsing = 'false';

      icon.src = friend.icon;
      icon.alt = friend.name;
      selectedUrl = friend.url;
      if (link) link.textContent = formatUrl(friend.url);

      resetShell();

      const markReady = () => {
        btn.disabled = false;
        machine.dataset.animating = 'false';
        btn.dataset.ready = 'true';
        capsule.dataset.pulsing = 'true';
      };

      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (reduce) {
        if (shell) {
          shell.dataset.shellFrame = '3';
          shell.dataset.open = 'true';
          shell.dataset.shaking = 'false';
        }
        capsule.hidden = false;
        capsule.dataset.pulling = 'true';
        haptic(18);
        markReady();
        return;
      }

      haptic([10, 20, 12]);
      machine.dataset.frame = '2';
      setTimeout(() => {
        haptic([8, 26, 8]);
      }, 90);
      setTimeout(() => {
        machine.dataset.frame = '3';
      }, 140);

      const shakeDur = 340;
      const pause1 = 120;
      const pause2 = 140;
      const openSwapDelay = 320;

      const t0 = 260;
      const t1 = t0 + shakeDur;
      const t2 = t1 + pause1;
      const t3 = t2 + shakeDur;
      const t4 = t3 + pause2;
      const t5 = t4 + openSwapDelay;

      setTimeout(() => {
        capsule.hidden = false;
        capsule.offsetHeight;
        if (shell) {
          shell.dataset.shellFrame = '1';
          shell.dataset.shaking = 'true';
          shell.dataset.open = 'false';
        }
      }, t0);

      setTimeout(() => {
        if (shell) {
          shell.dataset.shaking = 'false';
          shell.dataset.shellFrame = '1';
          shell.dataset.open = 'false';
        }
      }, t1);

      setTimeout(() => {
        if (shell) {
          shell.dataset.shaking = 'true';
          shell.dataset.shellFrame = '1';
          shell.dataset.open = 'false';
        }
      }, t2);

      setTimeout(() => {
        if (shell) {
          shell.dataset.shaking = 'false';
          shell.dataset.shellFrame = '1';
          shell.dataset.open = 'false';
        }
      }, t3);

      setTimeout(() => {
        if (shell) {
          shell.dataset.shellFrame = '2';
          shell.dataset.open = 'false';
        }
      }, t4);

      setTimeout(() => {
        if (shell) {
          shell.dataset.shellFrame = '3';
          shell.dataset.open = 'true';
        }
        capsule.dataset.pulling = 'true';
        haptic([18, 24, 12]);
        markReady();
      }, t5);
    }

    btn.addEventListener('click', (e) => {
      if (btn.dataset.ready === 'true') {
        const faceHit = e.target.closest('[data-friend-face],[data-friend-link]');
        const machineHit = e.target.closest('[data-friend-gacha-machine]');

        if (faceHit && selectedUrl) {
          window.open(selectedUrl, '_blank', 'noopener,noreferrer');
        }
        else if (machineHit) {
          const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

          btn.disabled = true;
          btn.dataset.ready = 'false';

          capsule.hidden = false;
          capsule.dataset.pulling = 'false';
          capsule.dataset.pulsing = 'true';

          if (shell) {
            shell.dataset.open = 'false';
            shell.dataset.shaking = 'false';
            shell.dataset.shellFrame = '3';
            shell.dataset.return = 'false';
          }

          machine.dataset.frame = '1';
          machine.dataset.animating = 'false';
          machine.dataset.spinning = 'false';

          if (reduce) {
            if (shell) {
              shell.dataset.shellFrame = '1';
              shell.dataset.return = 'false';
            }
            capsule.hidden = true;
            capsule.dataset.pulling = 'false';
            capsule.dataset.pulsing = 'false';
            btn.disabled = false;
            return;
          }

          setTimeout(() => {
            if (shell) shell.dataset.shellFrame = '2';
            capsule.dataset.pulsing = 'false';
          }, 160);

          setTimeout(() => {
            if (shell) {
              shell.dataset.shellFrame = '1';
              shell.dataset.return = 'false';
            }
          }, 340);

          setTimeout(() => {
            if (shell) shell.dataset.return = 'true';
          }, 440);

          setTimeout(() => {
            capsule.hidden = true;
            capsule.dataset.pulling = 'false';
            capsule.dataset.pulsing = 'false';
            if (shell) shell.dataset.return = 'false';
            btn.disabled = false;
          }, 780);
        }
        return;
      }
      if (!capsule || !icon || !machine || FRIEND_GACHA.length === 0) return;

      let last = null;
      try {
        last = window.localStorage.getItem(STORAGE_LAST);
      } catch {}
      const friend = weightedPick(last);
      try {
        window.localStorage.setItem(STORAGE_LAST, friend.id);
      } catch {}

      startRoll(friend);
    });
  }

  function positionFriendGacha() {
    const gacha = document.querySelector('.friend-gacha');
    if (!gacha) return;
    const favoritesSection = Array.from(document.querySelectorAll('.about__section')).find((s) =>
      s.querySelector('.faves')
    );
    if (!favoritesSection) return;

    const about = document.querySelector('.about');
    if (!about) return;

    const nav = about.querySelector('.about__nav');

    requestAnimationFrame(() => {
      const aboutRect = about.getBoundingClientRect();
      const fRect = favoritesSection.getBoundingClientRect();
      const desiredTop = Math.max(0, fRect.top - aboutRect.top);

      let maxTop = desiredTop;
      if (nav) {
        const navRect = nav.getBoundingClientRect();
        const gachaRect = gacha.getBoundingClientRect();
        const padding = 16;
        maxTop = Math.max(0, navRect.top - aboutRect.top - gachaRect.height - padding);
      }

      const clampedTop = Math.min(desiredTop, maxTop);
      gacha.style.setProperty('--gacha-top', `${clampedTop}px`);
    });
  }

  let scheduledGachaPos = false;
  function scheduleFriendGachaPosition() {
    if (scheduledGachaPos) return;
    scheduledGachaPos = true;
    requestAnimationFrame(() => {
      scheduledGachaPos = false;
      positionFriendGacha();
    });
  }

  function bindFriendGachaPositioning() {
    const about = document.querySelector('.about');
    const gacha = document.querySelector('.friend-gacha');
    const favoritesSection = Array.from(document.querySelectorAll('.about__section')).find((s) =>
      s.querySelector('.faves')
    );
    if (!about || !gacha || !favoritesSection) return;
    if (gacha.dataset.posBound === 'true') return;
    gacha.dataset.posBound = 'true';

    scheduleFriendGachaPosition();

    window.addEventListener('resize', scheduleFriendGachaPosition, { passive: true });

    const ro = new ResizeObserver(() => scheduleFriendGachaPosition());
    ro.observe(about);
    ro.observe(favoritesSection);
    const machine = gacha.querySelector('[data-friend-gacha-machine]');
    if (machine) {
      machine.addEventListener('load', scheduleFriendGachaPosition, { once: true });
      machine.addEventListener('error', scheduleFriendGachaPosition, { once: true });
    }
  }

  runFavorites();
  bindDice();
  bindFriendGacha();
  bindFriendGachaPositioning();
  scheduleFriendGachaPosition();
  document.addEventListener('astro:page-load', () => {
    runFavorites();
    bindDice();
    bindFriendGacha();
    bindFriendGachaPositioning();
    scheduleFriendGachaPosition();
  });

  function bindFriendTilt() {
    const btn = document.querySelector('[data-friend-gacha]');
    if (!btn || btn.dataset.tiltBound === 'true') return;
    btn.dataset.tiltBound = 'true';

    const maxTilt = 32;

    function updateTilt(event) {
      const rect = btn.getBoundingClientRect();
      const x = (event.clientX - rect.left) / rect.width - 0.5;
      const y = (event.clientY - rect.top) / rect.height - 0.5;
      const rotateX = (-y * maxTilt).toFixed(2);
      const rotateY = (x * maxTilt).toFixed(2);
      const glowX = (x * 70).toFixed(2);
      const glowY = (y * 70).toFixed(2);

      btn.style.setProperty('--tilt-rotate-x', `${rotateX}deg`);
      btn.style.setProperty('--tilt-rotate-y', `${rotateY}deg`);
      btn.style.setProperty('--tilt-glow-x', `${glowX}px`);
      btn.style.setProperty('--tilt-glow-y', `${glowY}px`);
      btn.style.setProperty('--tilt-intensity', '1');
    }

    function resetTilt() {
      btn.style.setProperty('--tilt-rotate-x', '0deg');
      btn.style.setProperty('--tilt-rotate-y', '0deg');
      btn.style.setProperty('--tilt-glow-x', '0px');
      btn.style.setProperty('--tilt-glow-y', '0px');
      btn.style.setProperty('--tilt-intensity', '0');
    }

    btn.addEventListener('pointermove', updateTilt);
    btn.addEventListener('pointerleave', resetTilt);
    btn.addEventListener('pointerdown', () => {
      btn.style.setProperty('--tilt-intensity', '1.2');
    });
    btn.addEventListener('pointerup', () => {
      btn.style.setProperty('--tilt-intensity', '1');
    });

    resetTilt();
  }

  bindFriendTilt();
  document.addEventListener('astro:page-load', bindFriendTilt);
</script>

<style>
  .about {
    max-width: 40rem;
    position: relative;
  }

  .about__title {
    font-family: var(--font-display);
    font-size: var(--text-title);
    font-weight: 400;
    color: var(--text);
    line-height: var(--line-body);
    margin-bottom: var(--space-md);
  }

  .about__body {
    display: flex;
    flex-direction: column;
    gap: var(--space-2xl);
  }

  .about__section p {
    font-size: var(--text-body);
    color: var(--text);
    margin-bottom: var(--space-md);
  }

  .about__closing {
    font-size: var(--text-body);
    color: var(--text-muted);
  }

  .about__email {
    color: var(--text-muted);
    font-size: var(--text-small);
  }

  .inline-link {
    color: inherit;
    text-decoration: underline;
    text-decoration-thickness: 2px;
    text-underline-offset: 3px;
    text-decoration-color: var(--accent);
  }

  .inline-link:hover {
    color: var(--accent);
  }

  .about__section p:last-child {
    margin-bottom: 0;
  }

  .about__heading-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
    margin-bottom: var(--space-lg);
  }

  .about__heading {
    font-family: var(--font-display);
    font-size: var(--text-small);
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-muted);
  }

  .favorites-dice {
    appearance: none;
    -webkit-appearance: none;
    border: none;
    padding: 0;
    background: none;
    opacity: 0.75;
    transform-origin: center;
    transition: opacity 0.2s var(--ease);
    cursor: pointer;
  }

  .favorites-dice[data-rolling='true'] {
    opacity: 1;
  }

  .favorites-dice:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 4px;
    border-radius: 7px;
  }

  .dice {
    width: 20px;
    height: 20px;
    display: inline-block;
    border-radius: 5px;
    border: 1px solid var(--border);
    background: var(--bg-card);
    position: relative;
    box-shadow: 0 1px 0 color-mix(in srgb, var(--text) 10%, transparent);
